# Streamlit Cloud secrets. Paste this into the Streamlit Cloud
# dashboard for your app (Settings > Secrets) and fill in real values.
# Streamlit promotes these to environment variables at runtime, so
# pydantic-settings will pick them up the same way it picks up .env locally.

SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "eyJ...service_role_key..."

DATABASE_URL = "postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

OPENAI_API_KEY = "sk-..."

# Defaults match KARR-AI; uncomment to override.
# COMPLIANCE_EMBED_MODEL = "text-embedding-3-large"
# COMPLIANCE_EMBED_DIMS = 3072
# GEN_MODEL = "gpt-5.5"

GATE_PASSWORD = "change-me-please"
GATE_USER_ID = "00000000-0000-0000-0000-000000000000"
