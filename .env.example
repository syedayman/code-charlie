# Copy to .env and fill in. For Streamlit Cloud, paste the same values
# into .streamlit/secrets.toml (see secrets.toml.example).

# ----- Supabase (shared with KARR-AI) ---------------------------------------
# Same project as KARR-AI so compliance_embeddings is read directly.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# Session-pooler connection string for LangGraph checkpoints.
# Supabase Dashboard > Connect > Session pooler.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ----- OpenAI ---------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional overrides — defaults match KARR-AI Code Charlie behavior.
# COMPLIANCE_EMBED_MODEL=text-embedding-3-large
# COMPLIANCE_EMBED_DIMS=3072
# GEN_MODEL=gpt-5.5

# ----- Streamlit gate -------------------------------------------------------
# Single shared password to access the app.
GATE_PASSWORD=change-me-please

# Fixed UUID owning every Streamlit session. Generate once:
#   python -c "import uuid; print(uuid.uuid4())"
GATE_USER_ID=00000000-0000-0000-0000-000000000000
